# HomeSphere Environment Variables

# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:8000

# Backend (FastAPI)
BACKEND_PORT=8000
BACKEND_HOST=localhost
DEBUG=true

# Database
# For SQLite (default, offline)
DATABASE_URL=sqlite:///./homesphere.db

# For PostgreSQL (optional, online)
# DATABASE_URL=postgresql://username:password@localhost:5432/homesphere

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=your-email@gmail.com
EMAIL_USE_TLS=true

# File Storage
UPLOAD_DIR=./backend/static/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=homesphere.log

# Weather API (for weather widget)
WEATHER_API_KEY=your-weather-api-key

# AI API (for AI features)
AI_API_KEY=your-ai-api-key
AI_API_URL=https://api.openai.com/v1