# HomeSphere Backend Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database Configuration
# For SQLite (offline mode - default)
DATABASE_URL=sqlite:///./homesphere.db

# For PostgreSQL (online mode)
# DATABASE_URL=postgresql://username:password@localhost:5432/homesphere

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups
EXPORT_DIR=./exports

# CORS
ALLOW_ORIGINS=*

# AI Configuration
# OPENAI_API_KEY=your-openai-api-key
